---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';

export async function getStaticPaths() {
  const micros = await getCollection('micro');
  const tags = [...new Set(micros.flatMap((m) => m.data.tags || []))];

  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      micros: micros
        .filter((m) => m.data.tags?.includes(tag))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { tag, micros } = Astro.props;

const rendered = await Promise.all(
  micros.map(async (micro) => {
    const { Content } = await render(micro);
    return { micro, Content };
  })
);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    hour: 'numeric',
    minute: '2-digit',
  });
}

const archetypeColors: Record<string, string> = {
  'Product Mind': '#6366f1',
  'Systems Architect': '#0891b2',
  'AI Process Engineer': '#9333ea',
  'Domain Expert': '#c2410c',
  'Quality & Trust': '#16a34a',
};
---

<Base title={`Signals: ${tag}`}>
  <div class="page-header">
    <h1>Signals: {tag}</h1>
    <p>{micros.length} {micros.length === 1 ? 'signal' : 'signals'}</p>
  </div>

  <div class="micro-feed">
    {rendered.map(({ micro, Content }) => (
      <div class="micro-entry">
        <div class="micro-meta">
          <time datetime={micro.data.date.toISOString()}>
            {formatDate(micro.data.date)}
          </time>
          {micro.data.archetype && (
            <span class="archetype-badge" style={`--archetype-color: ${archetypeColors[micro.data.archetype] || '#666'}`}>
              {micro.data.archetype}
            </span>
          )}
        </div>
        <div class="micro-content">
          <Content />
        </div>
        {micro.data.tags && micro.data.tags.length > 0 && (
          <div class="micro-tags">
            {micro.data.tags.map((tag) => (
              <a href={`/signals/tag/${tag}`} class="tag">{tag}</a>
            ))}
          </div>
        )}
      </div>
    ))}
  </div>

  <div class="ornament">· · ·</div>

  <p><a href="/signals">← Back to all signals</a></p>
</Base>
